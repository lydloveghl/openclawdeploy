{
  "name": "openclawdeploy",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "One-click OpenClaw deployment toolkit for macOS, Linux, and Windows.",
  "main": "./desktop/main.mjs",
  "bin": {
    "openclawdeploy": "./scripts/deploy.mjs"
  },
  "scripts": {
    "deploy": "node ./scripts/deploy.mjs --help",
    "wizard": "node ./scripts/deploy.mjs --interactive",
    "gui": "node ./scripts/gui.mjs",
    "desktop": "node ./scripts/build-catalog.mjs && electron .",
    "catalog": "node ./scripts/build-catalog.mjs",
    "package:desktop": "node ./scripts/build-catalog.mjs && electron-builder",
    "package:dmg": "node ./scripts/build-catalog.mjs && electron-builder --mac dmg",
    "package:exe": "node ./scripts/build-catalog.mjs && electron-builder --win nsis",
    "package:mac": "node ./scripts/package-macos-app.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ai.openclaw.deploy.installer",
    "productName": "OpenClawDeploy",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "catalog/**/*",
      "desktop/**/*",
      "gui/**/*",
      "scripts/**/*",
      "install.sh",
      "install.ps1",
      "README.md",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
