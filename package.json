{
  "name": "openclawdeploy",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "One-click OpenClaw deployment toolkit for macOS, Linux, and Windows.",
  "bin": {
    "openclawdeploy": "./scripts/deploy.mjs"
  },
  "scripts": {
    "deploy": "node ./scripts/deploy.mjs --help",
    "wizard": "node ./scripts/deploy.mjs --interactive",
    "gui": "node ./scripts/gui.mjs",
    "package:mac": "node ./scripts/package-macos-app.mjs"
  },
  "engines": {
    "node": ">=22"
  }
}
